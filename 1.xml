    if(nowFullAdOpen!==true&&ysdk!==null){
      ysdk.adv.showFullscreenAdv({callbacks:{
        onOpen: function(){ console.log('Open Ad Interstitial'); nowFullAdOpen=true;
          if(initGame) myGameInstance.SendMessage('YandexGame','OpenFullAd'); },
        onClose: function(was){ nowFullAdOpen=false;
          if(initGame) myGameInstance.SendMessage('YandexGame','CloseFullAd',was?'true':'false');
          FocusGame(); },
        onError: function(e){ console.error(e);
          if(myGameInstance) myGameInstance.SendMessage('YandexGame','ErrorFullAd'); FocusGame(); }
      }});
    }
  }catch(e){ console.error('CRASH FullAd Show:',e.message); }
}

function RewardedShow(id){
