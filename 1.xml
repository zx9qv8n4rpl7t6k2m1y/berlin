/* ── PART İNDİRME ───────────────────────────────────────────── */
/* baseProgress: bu dosya için progress barın başlangıç yüzdesi (0-1)
   rangeSize:    bu dosya için ayrılan progress oranı (0-1)
   DATA  → baseProgress=0.00, rangeSize=0.45  (0%–45%)
   WASM  → baseProgress=0.45, rangeSize=0.45  (45%–90%)
   Unity → 90%–100% Unity'nin kendi progress'i */
async function fetchFromUrls(urls, baseProgress, rangeSize) {
  baseProgress = baseProgress || 0;
  rangeSize    = rangeSize    || 0.5;
  var parts=[];
  for(var i=0;i<urls.length;i++){
    var r=await fetch(urls[i]);
    if(!r.ok) throw new Error('Part '+i+' HTTP '+r.status+': '+urls[i]);
    parts.push(new Uint8Array(await r.arrayBuffer()));
    /* Progress güncelle */
    var pct = baseProgress + rangeSize * ((i+1) / urls.length);
    progressBarFull.style.width = (pct * 100).toFixed(1) + '%';
    console.log('[Parts] '+i+'/'+(urls.length-1)+' loaded: '+parts[parts.length-1].length+' bytes | progress: '+(pct*100).toFixed(0)+'%');
  }
  var total=parts.reduce(function(s,p){return s+p.length;},0);
  var merged=new Uint8Array(total); var off=0;
  for(var j=0;j<parts.length;j++){merged.set(parts[j],off);off+=parts[j].length;}
  console.log('[Parts] merged: '+total+' bytes');
  return merged;
}
function brotliBlobUrl(uint8,filename){
  var blob=new Blob([uint8],{type:'application/octet-stream'});
  return URL.createObjectURL(blob)+'#'+encodeURIComponent(filename);
}

