    ysdk.adv.showRewardedVideo({callbacks:{
      onOpen:     function(){ myGameInstance.SendMessage('YandexGame','OpenVideo'); },
      onClose:    function(){ myGameInstance.SendMessage('YandexGame','CloseVideo'); FocusGame(); },
      onRewarded: function(){ myGameInstance.SendMessage('YandexGame','RewardVideo',id); },
      onError:    function(e){ console.error(e); myGameInstance.SendMessage('YandexGame','ErrorVideo'); }
    }});
  }catch(err){ console.error('CRASH Rewarded:',err.message); }
}

function StickyAdActivity(show){
  try{
    ysdk.adv.getBannerAdvStatus().then(function(d){
      if(d.stickyAdvIsShowing){ if(!show) ysdk.adv.hideBannerAdv(); }
      else if(d.reason) console.log('Sticky not shown:',d.reason);
      else if(show) ysdk.adv.showBannerAdv();
    });
  }catch(e){ console.error('CRASH Sticky:',e.message); }
}

/* ── CLOUD SAVE ─────────────────────────────────────────────── */
function SaveCloud(jsonData,flush){
  if(!player){ console.error('CRASH Save Cloud: no player'); return; }
  try{ player.setData({saves:[jsonData]},flush); }catch(e){ console.error(e); }
}
function LoadCloud(sendback){
  return new Promise(function(resolve){
    if(!ysdk){ if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetLoadSaves','noData'); resolve('noData'); return; }
    try{
      ysdk.getPlayer({scopes:false}).then(function(_p){
        _p.getData(["saves"]).then(function(data){
          var r=data.saves?JSON.stringify(data.saves):'noData';
          if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetLoadSaves',r);
          resolve(r);
        }).catch(function(){ if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetLoadSaves','noData'); resolve('noData'); });
      }).catch(function(e){ console.error(e); if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetLoadSaves','noData'); resolve('noData'); });
    }catch(e){ console.error(e); resolve('noData'); }
  });
}

/* ── PAYMENTS ───────────────────────────────────────────────── */
function GetPayments(sendback){
  return new Promise(function(resolve){
    try{
      if(!ysdk){ resolve('none'); return; }
      ysdk.getPayments().then(function(_p){
        payments=_p;
        _p.getCatalog().then(function(products){
          _p.getPurchases().then(function(purchases){
            var ids=[],titles=[],descs=[],imgs=[],prices=[],pvals=[],codes=[],imgURLs=[],cons=[];
            for(var i=0;i<products.length;i++){
              ids[i]=products[i].id; titles[i]=products[i].title; descs[i]=products[i].description;
              imgs[i]=products[i].imageURI; prices[i]=products[i].price; pvals[i]=products[i].priceValue;
              codes[i]=products[i].priceCurrencyCode; imgURLs[i]=products[i].getPriceCurrencyImage("medium");
              cons[i]=true;
              for(var i2=0;i2<purchases.length;i2++){ if(purchases[i2].productID===ids[i]){cons[i]=false;break;} }
            }
            var j=JSON.stringify({id:ids,title:titles,description:descs,imageURI:imgs,price:prices,
              priceValue:pvals,priceCurrencyCode:codes,currencyImageURL:imgURLs,consumed:cons,
              language:ysdk.environment.i18n.lang});
            if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','PaymentsEntries',j);
            resolve(j);
          });
        });
      }).catch(function(e){ console.log('Purchases not available',e.message); resolve('none'); });
    }catch(e){ console.error(e); resolve('none'); }
  });
}
function BuyPayments(id){
  try{
    if(payments){ payments.purchase(id).then(function(){ ConsumePurchase(id); FocusGame(); })
      .catch(function(e){ console.error(e); myGameInstance.SendMessage('YandexGame','OnPurchaseFailed',id); FocusGame(); });
    }
  }catch(e){ console.error(e); FocusGame(); }
}
function ConsumePurchase(id){
  try{
    if(payments) payments.getPurchases().then(function(ps){
      for(var i=0;i<ps.length;i++) if(ps[i].productID===id){
        payments.consumePurchase(ps[i].purchaseToken);
        myGameInstance.SendMessage('YandexGame','OnPurchaseSuccess',id);
      }
    });
  }catch(e){ console.error(e); }
}
function ConsumePurchases(){
  try{
    if(payments) payments.getPurchases().then(function(ps){
      for(var i=0;i<ps.length;i++){
        payments.consumePurchase(ps[i].purchaseToken);
        myGameInstance.SendMessage('YandexGame','OnPurchaseSuccess',ps[i].productID);
      }
    });
  }catch(e){ console.error(e); }
}

/* ── LEADERBOARDS ───────────────────────────────────────────── */
function InitLeaderboards(){
  ysdk.getLeaderboards().then(function(_lb){ leaderboard=_lb; });
}
function WaitForLeaderboard(){
  return new Promise(function(resolve,reject){
    var iv=setInterval(function(){
      if(leaderboard!==null){clearInterval(iv);clearTimeout(to);resolve();}
    },100);
    var to=setTimeout(function(){clearInterval(iv);reject(new Error("LB timeout"));},5000);
  });
}
async function GetLeaderboardScores(nameLB,maxPlayers,quantityTop,quantityAround,photoSize,auth){
  try{
    if(!leaderboard) await WaitForLeaderboard();
    var j={technoName:'',isDefault:false,isInvertSortOrder:false,decimalOffset:0,type:''};
    ysdk.getLeaderboards().then(function(lb){ return lb.getLeaderboardDescription(nameLB); })
    .then(function(res){
      j.technoName=nameLB; j.isDefault=res.default;
      j.isInvertSortOrder=res.description.invert_sort_order;
      j.decimalOffset=res.description.score_format.options.decimal_offset;
      j.type=res.description.type;
      return leaderboard.getLeaderboardEntries(nameLB,{quantityTop:quantityTop,includeUser:auth,quantityAround:quantityAround});
    }).then(function(res){
      var jp=EntriesLB(res,maxPlayers,photoSize);
      myGameInstance.SendMessage('YandexGame','LeaderboardEntries',JSON.stringify(Object.assign({},j,jp)));
    }).catch(function(e){console.error(e);});
  }catch(e){console.error('CRASH Get LB:',e.message);}
}
async function SetLeaderboardScores(name,score){
  try{
    if(!leaderboard) await WaitForLeaderboard();
    ysdk.getLeaderboards().then(function(lb){ lb.setLeaderboardScore(name,score); });
  }catch(e){console.error('CRASH Set LB:',e.message);}
}
function EntriesLB(res,maxPlayers,photoSize){
  var n=Math.min(res.entries.length,maxPlayers),txt='',ranks=[],photos=[],names=[],scores=[],uids=[];
  for(var i=0;i<n;i++){
    ranks[i]=res.entries[i].rank; scores[i]=res.entries[i].score;
    uids[i]=res.entries[i].player.uniqueID;
    photos[i]=res.entries[i].player.getAvatarSrc(photoSize);
    names[i]=res.entries[i].player.scopePermissions.public_name==='allow'
      ?res.entries[i].player.publicName:'anonymous';
    txt+=ranks[i]+'. '+names[i]+': '+scores[i]+'\n';
  }
  return{entries:n===0?'no data':txt,ranks:ranks,photos:photos,names:names,scores:scores,uniqueIDs:uids};
}

/* ── ENVIRONMENT ────────────────────────────────────────────── */
function RequestingEnvironmentData(sendback){
  return new Promise(function(resolve){
    if(!ysdk){ resolve('null'); return; }
    try{
      var promptCanShow=false, reviewCanShow=false;
      ysdk.feedback.canReview().then(function(d){
        if(d.value) reviewCanShow=true;
        ysdk.shortcut.canShowPrompt().then(function(prompt){
          if(prompt.canShow) promptCanShow=true;
          var ua=navigator.userAgent, browser;
          if(ua.includes('YaBrowser')||ua.includes('YaSearchBrowser')) browser='Yandex';
          else if(ua.includes('Opera')||ua.includes('OPR')) browser='Opera';
          else if(ua.includes('Firefox')) browser='Firefox';
          else if(ua.includes('MSIE')) browser='IE';
          else if(ua.includes('Edge')) browser='Edge';
          else if(ua.includes('Chrome')) browser='Chrome';
          else if(ua.includes('Safari')) browser='Safari';
          else browser='Other';
          var j=JSON.stringify({
            language:ysdk.environment.i18n.lang, domain:ysdk.environment.i18n.tld,
            deviceType:ysdk.deviceInfo.type, isMobile:ysdk.deviceInfo.isMobile(),
            isDesktop:ysdk.deviceInfo.isDesktop(), isTablet:ysdk.deviceInfo.isTablet(),
            isTV:ysdk.deviceInfo.isTV(), appID:ysdk.environment.app.id,
            browserLang:ysdk.environment.browser.lang, payload:ysdk.environment.payload,
            promptCanShow:promptCanShow, reviewCanShow:reviewCanShow,
            platform:navigator.platform, browser:browser
          });
          environmentData=j;
          if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetEnvirData',j);
          resolve(j);
          console.log("Environment Data: "+j);
        });
      });
    }catch(e){ console.error(e); resolve('null'); }
  });
}

/* ── PLAYER ─────────────────────────────────────────────────── */
function InitPlayer(sendback){
  return new Promise(function(resolve){
    try{
      if(!ysdk){
        var r=NotAuthorized();
        if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetInitializationSDK',r);
        resolve(r); return;
      }
      ysdk.getPlayer({scopes:true}).then(function(_p){
        player=_p;
        if(player.getMode()==='lite'){
          var r=NotAuthorized();
          if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetInitializationSDK',r);
          resolve(r);
        } else {
          var j=JSON.stringify({playerAuth:'resolved',playerName:player.getName(),
            playerId:player.getUniqueID(),playerPhoto:player.getPhoto('small'),
            payingStatus:player.getPayingStatus()});
          if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetInitializationSDK',j);
          resolve(j);
        }
      }).catch(function(e){
        console.error(e);
        var r=NotAuthorized();
        if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetInitializationSDK',r);
        resolve(r);
      });
    }catch(e){
      console.error(e);
      var r=NotAuthorized();
      if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetInitializationSDK',r);
      resolve(r);
    }
  });
}
function NotAuthorized(){
  return JSON.stringify({playerAuth:'rejected',playerName:'unauthorized',
    playerId:'unauthorized',playerPhoto:'unknown',payingStatus:'unknown'});
}
function OpenAuthDialog(){
  if(!ysdk) return;
  try{
    ysdk.auth.openAuthDialog().then(function(){
      InitPlayer(true).then(function(){ myGameInstance.SendMessage('YandexGame','GetDataInvoke'); });
    });
  }catch(e){ console.log('CRASH Open Auth Dialog:',e.message); }
}

/* ── REVIEW / PROMPT ────────────────────────────────────────── */
function Review(){
  try{
    ysdk.feedback.canReview().then(function(d){
      if(d.value){
        ysdk.feedback.requestReview().then(function(r){
          myGameInstance.SendMessage('YandexGame','ReviewSent',r.feedbackSent?'true':'false');
          FocusGame();
        });
      } else { FocusGame(); }
    });
  }catch(e){ console.error(e); FocusGame(); }
}
function PromptShow(){
  try{
    ysdk.shortcut.showPrompt().then(function(r){
      myGameInstance.SendMessage('YandexGame',r.outcome==='accepted'?'OnPromptSuccess':'OnPromptFail');
      FocusGame();
    });
  }catch(e){ console.error(e); FocusGame(); }
}

